# ── Aplicación ────────────────────────────────────────────────────────────────
APP_NAME=Kardex System
APP_VERSION=1.0.0
DEBUG=True

# ── Base de datos ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:admin12@localhost:5432/kardex_db

# ── Seguridad JWT ─────────────────────────────────────────────────────────────
SECRET_KEY=cambia_esta_clave_por_una_segura_en_produccion
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── CORS ──────────────────────────────────────────────────────────────────────
#ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
ALLOWED_ORIGINS='["http://localhost:5173", "http://localhost:3000"]'

# ── Archivos ──────────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=uploads

