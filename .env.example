# ── Aplicación ────────────────────────────────────────────────────────────────
APP_NAME=Kardex System
APP_VERSION=1.0.0
DEBUG=false

# ── Base de datos ─────────────────────────────────────────────────────────────
# En Docker, localhost → nombre del servicio "db"
DATABASE_URL=postgresql+asyncpg://postgres:admin12@db:5432/kardex_db

# ── Seguridad JWT ─────────────────────────────────────────────────────────────
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia_esta_clave_por_una_segura_en_produccion
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost", "http://localhost:80"]

# ── Archivos ──────────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=uploads
